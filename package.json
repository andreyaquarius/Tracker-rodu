{
  "name": "tracker-rodu",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader runner",
    "build": "tsc --noEmit && vite build --configLoader runner",
    "preview": "vite preview --configLoader runner",
    "lint": "tsc --noEmit --pretty false",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "node --test \"test/**/*.test.ts\"",
    "test:integration": "node --test \"test/integration/**/*.test.ts\"",
    "test:db": "supabase test db",
    "test:e2e": "node --test \"test/e2e/**/*.test.ts\"",
    "benchmark:family-tree": "node --test test/familyTreePerformance.test.ts",
    "functions:serve:index-finding": "supabase functions serve index-finding-fragment --env-file .env.functions.local --no-verify-jwt",
    "verify:pages": "node scripts/verify-pages-build.mjs",
    "qa:family-tree": "node scripts/family-tree-visual-qa.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.0",
    "@types/leaflet": "^1.9.21",
    "fuse.js": "^7.4.2",
    "leaflet": "^1.9.4",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.4.1",
    "supabase": "^2.108.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
